{
	"name": "@beecode/msh-test-contractor",
	"version": "1.0.1",
	"description": "Test Contractor",
	"keywords": [
		"testing",
		"contract",
		"mock",
		"vitest",
		"unit-test",
		"tdd"
	],
	"homepage": "https://github.com/beecode-rs/msh-test-contractor#readme",
	"bugs": {
		"url": "https://github.com/beecode-rs/msh-test-contractor/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beecode-rs/msh-test-contractor.git"
	},
	"license": "mit",
	"author": "Milos Bugarinovic <milos.bugarinovic@gmail.com> (https://milos.bugarinovic.com)",
	"type": "module",
	"imports": {
		"#packageJson": "./package.json",
		"#src": "./dist/index.js",
		"#src/*.js": "./dist/*.js",
		"#src/*": "./dist/*.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		},
		"./contract-reporter": {
			"types": "./dist/business/component/contractor/contract-reporter.d.ts",
			"import": "./dist/business/component/contractor/contract-reporter.js"
		},
		"./vitest-plugin": {
			"types": "./dist/vitest-plugin.d.ts",
			"import": "./dist/vitest-plugin.js"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"./dist"
	],
	"scripts": {
		"build": "npm run clean && npm run tsc && npm run fix-hybrid-lib-esm",
		"clean": "rimraf ./dist",
		"doc": "concurrently --group -c auto 'npm:doc:*'",
		"doc:api": "npx typedoc --tsconfig tsconfig.build.json",
		"doc:toc": "npx markdown-toc -i ./README.md",
		"docker-build": "docker build -f ./resource/docker/Dockerfile -t bc-msh-test-contractor ./",
		"docker-rmi": "docker rmi bc-msh-test-contractor",
		"docker-run-package-lock-update": "docker run --rm -v ./:/usr/app/ milosbugarinovic/msh-lib-base:node22.22.1-alpine3.23 npm i --package-lock-only",
		"docker-run-sh": "docker run --rm -it bc-msh-test-contractor sh",
		"fix-hybrid-lib-esm": "mkdir -p ./dist && cp ./package.json ./dist/_package.json && echo '{\"type\": \"module\", \"imports\": {\"#packageJson\": \"./_package.json\", \"#src\": \"./index.js\", \"#src/*.js\": \"./*.js\", \"#src/*\": \"./*.js\"}}' > ./dist/package.json",
		"init": "concurrently --group -c auto 'npm:init:*'",
		"init:git-config": "git config include.path ./.git-config",
		"init:husky": "npx husky init",
		"lint": "npm run lint-prettier && npm run lint-eslint && npm run lint-json",
		"lint-eslint": "eslint ./ --quiet",
		"lint-eslint-fix": "npm run lint-eslint -- --fix",
		"lint-fix": "npm run lint-prettier-fix && npm run lint-eslint-fix && npm run lint-json-fix",
		"lint-json": "npm run lint-json-fix -- -c",
		"lint-json-fix": "jsonsort -p * .*.json '!./dist' '!./test/node_modules' '!./resource' '!**/.env*'  '!**/.gitignore' -t",
		"lint-prettier": "prettier --check {**/*,*}.{js,ts,jsx,tsx,cjs,cts,mjs,mts,html}",
		"lint-prettier-fix": "prettier --write {**/*,*}.{js,ts,jsx,tsx,cjs,cts,mjs,mts,html}",
		"npm-bump-version": "npm --no-git-tag-version version",
		"npm-lock-file-generate": "npm i --package-lock-only --prefix ./",
		"npm-ncu-check": "npx ncu",
		"npm-ncu-update": "npx ncu -u",
		"npm-pack": "mkdir -p packages && npm pack --pack-destination=./packages",
		"npm-semantic-release": "semantic-release",
		"npm-semantic-release-check": "npm run npm-semantic-release -- --dry-run --no-ci",
		"test": "concurrently --group -c auto 'npm:test:*'",
		"test-coverage-unit": "npm run test:unit -- --coverage",
		"test-coverage-unit-publish": "codecov",
		"test:contract": "vitest --config=./vitest.config.contract.ts",
		"test:examples": "cd test-examples && npm run test",
		"test:int": "vitest --config=./vitest.config.int.ts",
		"test:unit": "vitest --config=./vitest.config.unit.ts",
		"tsc": "tsc -p tsconfig.build.json",
		"tsc-check": "npm run tsc -- --noEmit",
		"tsc-time": "npm run tsc -- --diagnostics",
		"tsc-watch": "npm run tsc -- -w --preserveWatchOutput",
		"watch": "rimraf ./dist && npm run tsc-watch"
	},
	"commitlint": {
		"extends": [
			"@commitlint/config-conventional"
		]
	},
	"config": {
		"commitizen": {
			"path": "node_modules/cz-conventional-changelog"
		}
	},
	"dependencies": {
		"@beecode/msh-config": "^1.2.2",
		"dotenv": "^17.4.2",
		"fast-deep-equal": "^3.1.3",
		"glob": "^13.0.6",
		"js-yaml": "^5.2.1"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@commitlint/prompt": "^21.2.0",
		"@types/deep-equal": "^1.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.9",
		"commitizen": "^4.3.2",
		"concurrently": "^10.0.3",
		"husky": "^9.1.7",
		"json-sort-cli": "^4.1.3",
		"lint-staged": "^17.0.8",
		"markdown-toc": "^1.2.0",
		"prettier": "^3.9.4",
		"rimraf": "^6.1.3",
		"tsc-watch": "^7.2.1",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.12.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=20",
		"npm": ">=10"
	}
}
